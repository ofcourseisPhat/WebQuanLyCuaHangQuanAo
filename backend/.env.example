# Database
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=clothing_store

# Security - CHANGE THIS in production
JWT_SECRET_KEY=super-secret-key-change-me
JWT_ACCESS_TOKEN_EXPIRES_HOURS=12
JWT_ACCESS_TOKEN_EXPIRES_REMEMBER_DAYS=30

# App
FLASK_ENV=development
CORS_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api/v1

# Email: "console" for local testing, "smtp" for real sending
MAIL_TRANSPORT=console
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=no-reply@luxe.local
MAIL_USE_TLS=true
